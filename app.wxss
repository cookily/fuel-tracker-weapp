page {
  background: #f8fafc;
  color: #0f172a;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.06);
}

.title {
  font-size: 36rpx;
  font-weight: 700;
}

.subtitle {
  color: #64748b;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.button-primary {
  background: #0f172a;
  color: #ffffff;
  border-radius: 18rpx;
  font-size: 28rpx;
}

.button-secondary {
  background: #e2e8f0;
  color: #0f172a;
  border-radius: 18rpx;
  font-size: 28rpx;
}

.button-danger {
  background: #ef4444;
  color: #ffffff;
  border-radius: 18rpx;
  font-size: 28rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.muted {
  color: #64748b;
}

.empty {
  padding: 48rpx 24rpx;
  text-align: center;
  color: #64748b;
}

.pill {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
  color: #334155;
  font-size: 22rpx;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.metric {
  background: #f8fafc;
  border-radius: 18rpx;
  padding: 20rpx;
}

.metric-label {
  color: #64748b;
  font-size: 22rpx;
}

.metric-value {
  font-size: 34rpx;
  font-weight: 700;
  margin-top: 10rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.input,
.picker,
.switch-row {
  background: #f8fafc;
  border-radius: 18rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.error {
  color: #dc2626;
  font-size: 22rpx;
  margin-top: 8rpx;
}

.record-item {
  border-bottom: 1rpx solid #e2e8f0;
  padding: 24rpx 0;
}

.record-item:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.actions button {
  flex: 1;
}

.trend-bar-row {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  height: 200rpx;
  margin-top: 24rpx;
}

.trend-bar-wrap {
  flex: 1;
  text-align: center;
}

.trend-bar {
  width: 100%;
  background: linear-gradient(180deg, #38bdf8, #0f172a);
  border-radius: 12rpx 12rpx 0 0;
}

.trend-label {
  font-size: 20rpx;
  color: #64748b;
  margin-top: 8rpx;
}
